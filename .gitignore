# ---------------------------------------------------------
# Общие правила игнорирования для репозитория студента
# ---------------------------------------------------------

# Системные файлы ОС
.DS_Store
Thumbs.db

# Конфигурации IDE/редакторов
.vscode/
.idea/
*.swp
*.swo

# Виртуальные окружения Python
.venv/
venv/
env/
ENV/
.conda/
.venv*/

# Кеши Python и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class

# Папки и файлы сборки/дистрибуции (если вдруг появятся)
build/
dist/
eggs/
*.egg-info/
.installed.cfg

# Кеши и артефакты тестов
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Журналы
*.log
logs/

# Кеши Jupyter Notebook
.ipynb_checkpoints

# Файлы окружения и конфигурации с потенциальными секретами
.env
*.env
.env.*
!.env.example

# Разное
*.tmp
*.bak
*.old

# Данные (датасеты) — большие, не храним в репозитории
data/
**/data/*.tar.gz
**/data/*.zip

# Кэш PyTorch (если создаётся в корне)
.torch/

# Результаты обучения модели (большие чекпоинты)
results/
**/results/

# Кэш Hugging Face datasets (обычно вне репозитория, но на всякий случай)
.cache/huggingface/

# Файлы весов моделей (большие)
*.pth
*.bin
*.ckpt
*.pt
*.h5

# Временные артефакты, которые могут появиться в папке artifacts
artifacts/*.tmp
artifacts/*.log

# Примечание: папка artifacts/ не игнорируется полностью, только временные файлы
# Сама папка и её содержимое (confusion_matrix.png, sample_predictions.csv) должны быть закоммичены.